{
  "datasets": [
    {
      "name": "uw_kpis",
      "displayName": "Underwriting KPIs",
      "queryLines": [
        "SELECT month, line_of_business, gross_written_premium_usd, net_written_premium_usd, incurred_loss_usd, claim_count, loss_ratio, expense_ratio, combined_ratio FROM serverless_stable_xhky6g_catalog.allianz_gold.underwriting_kpis "
      ]
    },
    {
      "name": "kpi_totals",
      "displayName": "KPI Totals",
      "queryLines": [
        "SELECT   SUM(gross_written_premium_usd) AS total_gwp,   SUM(net_written_premium_usd)   AS total_nwp,   SUM(incurred_loss_usd)         AS total_losses,   SUM(claim_count)               AS total_claims,   CASE WHEN SUM(gross_written_premium_usd) > 0        THEN SUM(incurred_loss_usd) / SUM(gross_written_premium_usd) END AS overall_loss_ratio FROM serverless_stable_xhky6g_catalog.allianz_gold.underwriting_kpis "
      ]
    },
    {
      "name": "claims_summary",
      "displayName": "Claims Summary",
      "queryLines": [
        "SELECT line_of_business, product, peril, claim_count, total_incurred_usd, avg_severity_usd, max_severity_usd, cat_claim_count, fraud_flag_count FROM serverless_stable_xhky6g_catalog.allianz_gold.claims_summary "
      ]
    },
    {
      "name": "exposure",
      "displayName": "Exposure Accumulation",
      "queryLines": [
        "SELECT state_code, cresta_zone, region, line_of_business, product, total_insured_value_usd, annual_premium_usd, policy_count FROM serverless_stable_xhky6g_catalog.allianz_gold.exposure_accumulation "
      ]
    },
    {
      "name": "solvency",
      "displayName": "Solvency Capital",
      "queryLines": [
        "SELECT metric, value_usd FROM serverless_stable_xhky6g_catalog.allianz_gold.solvency_capital "
      ]
    },
    {
      "name": "solvency_kpi",
      "displayName": "Solvency KPI",
      "queryLines": [
        "SELECT   MAX(CASE WHEN metric = 'Solvency Ratio' THEN value_usd END) AS solvency_ratio,   MAX(CASE WHEN metric = 'SCR (Total)'    THEN value_usd END) AS scr_total,   MAX(CASE WHEN metric = 'Own Funds'      THEN value_usd END) AS own_funds,   MAX(CASE WHEN metric = 'Market Value'   THEN value_usd END) AS market_value FROM serverless_stable_xhky6g_catalog.allianz_gold.solvency_capital "
      ]
    },
    {
      "name": "assets",
      "displayName": "Asset Portfolio",
      "queryLines": [
        "SELECT asset_class, rating, market_value_usd, book_value_usd, avg_yield_pct, avg_duration_yrs, avg_esg_score, position_count FROM serverless_stable_xhky6g_catalog.allianz_gold.asset_portfolio_summary "
      ]
    },
    {
      "name": "event_risk",
      "displayName": "NOAA Event Risk",
      "queryLines": [
        "SELECT alert_id, event_type, severity, urgency, effective_utc, expires_utc, state_code, state_name, exposed_tiv_usd, exposed_policy_count FROM serverless_stable_xhky6g_catalog.allianz_gold.event_risk_correlation "
      ]
    },
    {
      "name": "cat_events",
      "displayName": "Catastrophe Events",
      "queryLines": [
        "SELECT event_id, title, event_type, severity, event_time_utc, latitude, longitude, state_code, pml_estimate_usd FROM serverless_stable_xhky6g_catalog.allianz_gold.cat_event_pml "
      ]
    },
    {
      "name": "event_risk_totals",
      "displayName": "Event Risk Totals",
      "queryLines": [
        "SELECT   COUNT(*) AS active_alerts,   COUNT(DISTINCT state_code) AS states_with_alerts,   SUM(exposed_tiv_usd) AS total_exposed_tiv,   SUM(exposed_policy_count) AS total_exposed_policies FROM serverless_stable_xhky6g_catalog.allianz_gold.event_risk_correlation "
      ]
    }
  ],
